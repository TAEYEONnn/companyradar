# CompanyRadar AI provider
# AI_PROVIDER=nvidia | openai  (default: nvidia)
AI_PROVIDER=nvidia

# NVIDIA Build API (https://build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_MODEL=mistralai/mistral-medium-3.5-128b

# Optional OpenAI fallback (set AI_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CompanyRadar fit analysis quota (optional primary store; Supabase v046 is fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
FIT_QUOTA_SALT=
FIT_DAILY_CLIENT_LIMIT=10
FIT_DAILY_GLOBAL_LIMIT=200
FIT_IP_MINUTE_LIMIT=20
RESUME_DAILY_CLIENT_LIMIT=3
RESUME_DAILY_GLOBAL_LIMIT=300
RESUME_IP_MINUTE_LIMIT=10

# Optional, loaded only after analytics consent
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional Supabase sync
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI API route allowlist (comma-separated; at least one matching value required)
AI_ALLOWED_EMAILS=your@email.com
AI_ALLOWED_USER_IDS=<supabase-user-id>

# Optional beta access can also be managed through public.profiles.role
# after applying the Supabase migrations. Supported roles: owner, beta_user, blocked.

# Toss Payments billing
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# Server-only Supabase key for billing/credit mutations. Never expose this client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Optional comma-separated hosts/origins that may see developer-only test tools.
# Example: http://192.168.1.100:3000,http://192.168.10.1:3000
NEXT_PUBLIC_DEV_TOOL_ORIGINS=

# Public site origin used for password recovery redirects and canonical OG metadata.
# Example: https://your-production-domain.com
NEXT_PUBLIC_SITE_URL=

# Service contact email shown in admin reply templates and settings screen (optional)
NEXT_PUBLIC_SUPPORT_EMAIL=
